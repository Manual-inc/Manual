<UserControl
    x:Class="ManualWindow.Views.WorkflowGraphView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml">
    <UserControl.Resources>
        <Style x:Key="ZoomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#8CFFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- Win2D canvas for all graph geometry -->
        <canvas:CanvasControl x:Name="Surface"
            Draw="Surface_Draw"
            SizeChanged="Surface_SizeChanged"/>

        <!-- XAML overlay for action buttons (hit-testable) -->
        <Canvas x:Name="ActionLayer" IsHitTestVisible="True"/>

        <!-- Zoom controls: top-right -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="14" Orientation="Horizontal" Spacing="0">
            <Border Background="#2E3043"
                    CornerRadius="9" BorderBrush="#14FFFFFF" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <Button x:Name="ZoomInButton" Width="32" Height="30" Padding="0"
                            Click="ZoomIn_Click" Style="{StaticResource ZoomButtonStyle}">
                        <FontIcon Glyph="&#xE8A3;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                  Foreground="#8CFFFFFF"/>
                    </Button>
                    <Rectangle Width="1" Height="18" Fill="#14FFFFFF"/>
                    <Button x:Name="ZoomOutButton" Width="32" Height="30" Padding="0"
                            Click="ZoomOut_Click" Style="{StaticResource ZoomButtonStyle}">
                        <FontIcon Glyph="&#xE71F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                  Foreground="#8CFFFFFF"/>
                    </Button>
                    <Rectangle Width="1" Height="18" Fill="#14FFFFFF"/>
                    <Button x:Name="ZoomResetButton" Width="32" Height="30" Padding="0"
                            Click="ZoomReset_Click" Style="{StaticResource ZoomButtonStyle}">
                        <FontIcon Glyph="&#xE7B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                  Foreground="#8CFFFFFF"/>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
