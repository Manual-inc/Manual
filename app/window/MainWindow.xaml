<Window
    x:Class="ManualWindow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Why this exists: docs/wiki/analyses/2026-05-19-quick-start.md and
         docs/wiki/features/workflow-starters.md keep the first-success
         onboarding path visible even in the static Windows preview shell. -->
    <Grid Background="#15171B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="24,20,24,16"
            Padding="20,18"
            Background="#1D2026"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="16">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            Text="Manual"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#FFFBFBFB" />
                        <Border
                            Padding="10,4"
                            Background="#2B2F38"
                            CornerRadius="999">
                            <TextBlock
                                Text="Windows Preview"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#B3FFFFFF" />
                        </Border>
                    </StackPanel>

                    <TextBlock
                        Text="Optimization-first workflow console"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="#FFFBFBFB" />

                    <TextBlock
                        MaxWidth="760"
                        Text="Check connectivity, feel the demo, and move into the first real code review workflow without losing the optimization story."
                        TextWrapping="WrapWholeWords"
                        Foreground="#B3FFFFFF" />

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <Border
                            Padding="10,5"
                            Background="#222631"
                            CornerRadius="999">
                            <TextBlock
                                Text="1 Doctor"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#FFFBFBFB" />
                        </Border>
                        <Border
                            Padding="10,5"
                            Background="#222631"
                            CornerRadius="999">
                            <TextBlock
                                Text="2 Demo"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#FFFBFBFB" />
                        </Border>
                        <Border
                            Padding="10,5"
                            Background="#222631"
                            CornerRadius="999">
                            <TextBlock
                                Text="3 Code Review Starter"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#FFFBFBFB" />
                        </Border>
                        <Border
                            Padding="10,5"
                            Background="#222631"
                            CornerRadius="999">
                            <TextBlock
                                Text="4 Output"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#FFFBFBFB" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="14,10"
                    Background="#2A1D1A"
                    BorderBrush="#66FF6F5B"
                    BorderThickness="1"
                    CornerRadius="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Regression Risk"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#FFFF8E7E" />
                        <TextBlock
                            Text="Review step still drives most token cost"
                            Width="220"
                            TextWrapping="WrapWholeWords"
                            Foreground="#FFFBFBFB" />
                        <TextBlock
                            Text="Derived"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#B3FFFFFF" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="24,0,24,24"
            ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="18"
                Background="#1A1D23"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="18">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock
                                Text="Workflow Run"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#FFFBFBFB" />
                            <TextBlock
                                Text="starter-code-review-run · Completed"
                                Foreground="#99FFFFFF" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="10,6"
                            Background="#1F2A20"
                            CornerRadius="999">
                            <TextBlock
                                Text="2 nodes · output surfaced"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#FF95E08A" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#222631" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Token Usage" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                                <TextBlock Text="2,300" FontSize="24" FontWeight="SemiBold" Foreground="#FFFBFBFB" />
                                <TextBlock Text="bounded patch preview" Foreground="#FF95E08A" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#222631" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Verification" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                                <TextBlock Text="100%" FontSize="24" FontWeight="SemiBold" Foreground="#FFFBFBFB" />
                                <TextBlock Text="review output captured" Foreground="#FF95E08A" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#222631" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Time" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                                <TextBlock Text="2.6s" FontSize="24" FontWeight="SemiBold" Foreground="#FFFBFBFB" />
                                <TextBlock Text="starter-ready latency" Foreground="#FF95E08A" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid
                        Grid.Row="2"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Padding="16"
                            Background="#16191F"
                            CornerRadius="14">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Execution Timeline"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBFBFB" />

                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="workflow_started" Foreground="#FFFBFBFB" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="collect_diff completed" Foreground="#FFFBFBFB" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="review completed" Foreground="#FFFBFBFB" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="workflow_completed" Foreground="#FFFBFBFB" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            Background="#16191F"
                            CornerRadius="14">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Review Output"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBFBFB" />

                                <Border Background="#222631" CornerRadius="12" Padding="12">
                                    <TextBlock
                                        Text="No findings. Residual risk is low for this bounded starter change."
                                        TextWrapping="WrapWholeWords"
                                        Foreground="#FFFBFBFB" />
                                </Border>

                                <Border Background="#222631" CornerRadius="12" Padding="12">
                                    <TextBlock
                                        Text="If the patch preview is truncated, the review should say so explicitly and focus only on supported risks."
                                        TextWrapping="WrapWholeWords"
                                        Foreground="#FFFBFBFB" />
                                </Border>

                                <Border Background="#222631" CornerRadius="12" Padding="12">
                                    <TextBlock
                                        Text="Native clients should surface the review result directly, not hide it behind raw event dictionaries."
                                        TextWrapping="WrapWholeWords"
                                        Foreground="#B3FFFFFF" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Padding="18"
                Background="#1A1D23"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Quick Start Path"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFFBFBFB" />

                    <Border Background="#222631" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="1. Doctor" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                            <TextBlock Text="manual doctor" FontFamily="Consolas" Foreground="#FFFBFBFB" />
                            <TextBlock Text="Check local connectivity and follow the next-step hint before the first run." TextWrapping="WrapWholeWords" Foreground="#B3FFFFFF" />
                        </StackPanel>
                    </Border>

                    <Border Background="#222631" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="2. Demo" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                            <TextBlock Text="manual demo optimization" FontFamily="Consolas" Foreground="#FFFBFBFB" />
                            <TextBlock Text="Feel the workflow + optimization value in one guided path." TextWrapping="WrapWholeWords" Foreground="#B3FFFFFF" />
                        </StackPanel>
                    </Border>

                    <Border Background="#222631" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="3. Starter" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                            <TextBlock Text="manual workflow starter code-review --run" FontFamily="Consolas" TextWrapping="WrapWholeWords" Foreground="#FFFBFBFB" />
                            <TextBlock Text="Move from the demo into the first real repository review without hand-writing JSON." TextWrapping="WrapWholeWords" Foreground="#B3FFFFFF" />
                        </StackPanel>
                    </Border>

                    <Border Background="#222631" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="4. Output Surface" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                            <TextBlock Text="Review Output appears next to the run timeline." TextWrapping="WrapWholeWords" Foreground="#FFFBFBFB" />
                            <TextBlock Text="Measurements shown here stay derived until Windows runtime wiring is added." TextWrapping="WrapWholeWords" Foreground="#B3FFFFFF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
