<Window
    x:Class="ManualWindow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Why this exists: docs/wiki/systems/매뉴얼-최적화-기능.md makes optimization
         insight the core MVP value that every client surface should communicate. -->
    <Grid Background="#15171B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="24,20,24,16"
            Padding="20,18"
            Background="#1D2026"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            CornerRadius="16">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            Text="Manual"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#FFFBFBFB" />
                        <Border
                            Padding="10,4"
                            Background="#2B2F38"
                            CornerRadius="999">
                            <TextBlock
                                Text="Windows Preview"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#B3FFFFFF" />
                        </Border>
                    </StackPanel>

                    <TextBlock
                        Text="Optimization-first workflow console"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="#FFFBFBFB" />

                    <TextBlock
                        MaxWidth="760"
                        Text="Run a workflow, inspect execution evidence, and surface the next optimization move without leaving the main console."
                        TextWrapping="WrapWholeWords"
                        Foreground="#B3FFFFFF" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="14,10"
                    Background="#2A1D1A"
                    BorderBrush="#66FF6F5B"
                    BorderThickness="1"
                    CornerRadius="14">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Regression Risk"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#FFFF8E7E" />
                        <TextBlock
                            Text="Implementation step used most tokens"
                            Width="220"
                            TextWrapping="WrapWholeWords"
                            Foreground="#FFFBFBFB" />
                        <TextBlock
                            Text="Derived"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#B3FFFFFF" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="24,0,24,24"
            ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="18"
                Background="#1A1D23"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="18">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock
                                Text="Workflow Run"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#FFFBFBFB" />
                            <TextBlock
                                Text="demo-optimization-run · Completed"
                                Foreground="#99FFFFFF" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Padding="10,6"
                            Background="#1F2A20"
                            CornerRadius="999">
                            <TextBlock
                                Text="2 nodes · 1 recommendation"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#FF95E08A" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#222631" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Token Usage" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                                <TextBlock Text="6,200" FontSize="24" FontWeight="SemiBold" Foreground="#FFFBFBFB" />
                                <TextBlock Text="+4,400 vs baseline" Foreground="#FFFF8E7E" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#222631" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Verification" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                                <TextBlock Text="70%" FontSize="24" FontWeight="SemiBold" Foreground="#FFFBFBFB" />
                                <TextBlock Text="review evidence missing" Foreground="#FFD9C27A" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#222631" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Time" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                                <TextBlock Text="3.1s" FontSize="24" FontWeight="SemiBold" Foreground="#FFFBFBFB" />
                                <TextBlock Text="2 retries on implement" Foreground="#FF95E08A" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid
                        Grid.Row="2"
                        ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Padding="16"
                            Background="#16191F"
                            CornerRadius="14">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Execution Timeline"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBFBFB" />

                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="workflow_started" Foreground="#FFFBFBFB" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="brief completed" Foreground="#FFFBFBFB" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="digest completed" Foreground="#FFFBFBFB" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="09:41" Foreground="#80FFFFFF" />
                                        <TextBlock Grid.Column="1" Text="workflow_completed" Foreground="#FFFBFBFB" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            Background="#16191F"
                            CornerRadius="14">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Recommendations"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFFBFBFB" />

                                <Border Background="#222631" CornerRadius="12" Padding="12">
                                    <TextBlock
                                        Text="Preprocess file discovery before the main reasoning step."
                                        TextWrapping="WrapWholeWords"
                                        Foreground="#FFFBFBFB" />
                                </Border>

                                <Border Background="#222631" CornerRadius="12" Padding="12">
                                    <TextBlock
                                        Text="Keep the high-quality model on implementation, but downshift planning."
                                        TextWrapping="WrapWholeWords"
                                        Foreground="#FFFBFBFB" />
                                </Border>

                                <Border Background="#222631" CornerRadius="12" Padding="12">
                                    <TextBlock
                                        Text="Measurements shown here are derived from workflow events until Windows runtime wiring is added."
                                        TextWrapping="WrapWholeWords"
                                        Foreground="#B3FFFFFF" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Padding="18"
                Background="#1A1D23"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Optimization Signals"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFFBFBFB" />

                    <Border Background="#222631" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Main Issue" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                            <TextBlock Text="implementation step used most tokens" TextWrapping="WrapWholeWords" Foreground="#FFFBFBFB" />
                        </StackPanel>
                    </Border>

                    <Border Background="#222631" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Derived Measurements" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                            <TextBlock Text="Estimated from workflow events and workflow definition." TextWrapping="WrapWholeWords" Foreground="#B3FFFFFF" />
                        </StackPanel>
                    </Border>

                    <Border Background="#222631" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Bottlenecks" FontSize="12" FontWeight="SemiBold" Foreground="#99FFFFFF" />
                            <TextBlock Text="Token Waste: implement" Foreground="#FFFBFBFB" />
                            <TextBlock Text="Verification Gaps: review" Foreground="#FFFBFBFB" />
                            <TextBlock Text="Slow Steps: implement" Foreground="#FFFBFBFB" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
