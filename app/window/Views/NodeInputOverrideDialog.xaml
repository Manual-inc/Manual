<ContentDialog x:Class="ManualWindow.Views.NodeInputOverrideDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Override Input"
    PrimaryButtonText="Run with Overrides"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    MinWidth="480">
    <StackPanel Spacing="12" Width="480">
        <TextBlock FontSize="13" Opacity="0.65" TextWrapping="Wrap"
            Text="Enter a JSON object that will replace the node's input for this run."/>
        <TextBox x:Name="JsonInput"
            PlaceholderText="{}{&quot;key&quot;: &quot;value&quot;}"
            AcceptsReturn="True"
            MinHeight="160"
            FontFamily="Consolas, Courier New"
            FontSize="13"
            TextWrapping="Wrap"
            VerticalAlignment="Stretch"/>
        <TextBlock x:Name="ErrorText" FontSize="12" Foreground="#FFFF6E5C"
                   TextWrapping="Wrap" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
