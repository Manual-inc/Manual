{
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/target",
    "**/mutants.out",
    "**/mutants.out.old",
    "**/.mutants",
    "**/.cargo-mutants"
  ],
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "linkedProjects": [
          "./Cargo.toml"
        ]
      }
    }
  }
}
