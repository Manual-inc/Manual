<UserControl x:Class="ManualWindow.Views.EventTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- Empty state -->
        <TextBlock x:Name="EmptyText" Text="No events yet"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Opacity="0.35" FontSize="13"/>
        <!-- Event list -->
        <ListView x:Name="EventList"
                  SelectionMode="None"
                  Visibility="Collapsed">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="8" Padding="12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Time — rendered by code-behind via x:Name on container, using plain binding -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding TimeLabel}"
                                   FontSize="11" FontFamily="Consolas, Courier New"
                                   Opacity="0.45" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Detail}" FontSize="11" Opacity="0.6"
                                       TextWrapping="Wrap" MaxLines="2"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding NodeId}"
                                   FontSize="10" FontFamily="Consolas, Courier New"
                                   Opacity="0.4" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
