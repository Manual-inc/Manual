<UserControl x:Class="ManualWindow.Views.BottomPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:ManualWindow.Views">
    <Grid Background="{ThemeResource PanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="12,6" Height="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="EVENTS" FontSize="10" FontWeight="Bold"
                       Opacity="0.45" CharacterSpacing="70" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="ClearButton" Width="28" Height="28" Padding="0"
                    Click="Clear_Click" ToolTipService.ToolTip="Clear events">
                <FontIcon x:Name="ClearIcon" FontSize="11"
                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            </Button>
        </Grid>
        <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                   Fill="{ThemeResource StrokeBrush}"/>

        <views:EventTimelineView x:Name="Timeline" Grid.Row="1"/>
    </Grid>
</UserControl>
