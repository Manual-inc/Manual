<UserControl x:Class="ManualWindow.Views.WorkflowSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{ThemeResource PanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="WORKFLOWS" FontSize="10" FontWeight="Bold"
                       Opacity="0.45" CharacterSpacing="70" VerticalAlignment="Center"/>
            <Button x:Name="RefreshButton" Grid.Column="1" Width="28" Height="28" Padding="0"
                    Click="RefreshButton_Click" ToolTipService.ToolTip="Refresh">
                <FontIcon x:Name="RefreshIcon" FontSize="12"
                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            </Button>
        </Grid>
        <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="{ThemeResource StrokeBrush}"/>

        <!-- Workflow list -->
        <ListView x:Name="WorkflowList" Grid.Row="1"
                  SelectionMode="Single"
                  SelectionChanged="WorkflowList_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xF168;" FontSize="14"
                                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                  Opacity="0.6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding WorkflowId}" FontSize="13"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding NodeCount}" FontSize="11" Opacity="0.5"/>
                                <TextBlock Text="nodes" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>
                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="10"
                                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                  Opacity="0.45" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
