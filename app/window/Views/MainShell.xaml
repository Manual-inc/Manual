<UserControl x:Class="ManualWindow.Views.MainShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:ManualWindow.Views">

    <Grid Background="{ThemeResource CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomRow" Height="200"/>
        </Grid.RowDefinitions>

        <!-- TopBar: full width -->
        <views:TopBar x:Name="TopBar" Grid.Row="0"
            BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0,0,0,1"/>

        <!-- Main content row -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="InspectorColumn" Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: WorkflowSidebar -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0,0,1,0">
                <views:WorkflowSidebar x:Name="Sidebar"/>
            </Grid>

            <!-- Center: WorkflowGraphView -->
            <views:WorkflowGraphView x:Name="GraphView" Grid.Column="1"/>

            <!-- Right: NodeInspectorView -->
            <Grid Grid.Column="2" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="1,0,0,0">
                <views:NodeInspectorView x:Name="Inspector"/>
            </Grid>
        </Grid>

        <!-- Bottom: BottomPanel -->
        <Grid Grid.Row="2" BorderBrush="{ThemeResource StrokeBrush}" BorderThickness="0,1,0,0">
            <views:BottomPanel x:Name="BottomPanelView"/>
        </Grid>

        <!-- Toggle buttons (floating, bottom of left rail) -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Orientation="Horizontal" Margin="4" Spacing="2">
            <Button x:Name="ToggleSidebarButton" Width="28" Height="28" Padding="0"
                    Click="ToggleSidebar_Click" ToolTipService.ToolTip="Toggle sidebar">
                <FontIcon x:Name="SidebarIcon" Glyph="" FontSize="13"
                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            </Button>
            <Button x:Name="ToggleInspectorButton" Width="28" Height="28" Padding="0"
                    Click="ToggleInspector_Click" ToolTipService.ToolTip="Toggle inspector">
                <FontIcon Glyph="" FontSize="13"
                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            </Button>
            <Button x:Name="ToggleBottomButton" Width="28" Height="28" Padding="0"
                    Click="ToggleBottom_Click" ToolTipService.ToolTip="Toggle events panel">
                <FontIcon Glyph="" FontSize="13"
                          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
