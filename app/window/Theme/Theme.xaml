<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <SolidColorBrush x:Key="CanvasBrush"     Color="#FF292B36" />
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#0FFFFFFF" />
    <SolidColorBrush x:Key="PanelBrush"      Color="#FF21242B" />
    <SolidColorBrush x:Key="PanelElevBrush"  Color="#FF2E303B" />
    <SolidColorBrush x:Key="RailBrush"       Color="#FF1A1C21" />
    <SolidColorBrush x:Key="TopBarBrush"     Color="#FF21242B" />

    <!-- Node -->
    <SolidColorBrush x:Key="NodeCardBrush"   Color="#FF363845" />
    <SolidColorBrush x:Key="NodeStrokeBrush" Color="#1AFFFFFF" />

    <!-- Borders -->
    <SolidColorBrush x:Key="StrokeBrush"       Color="#14FFFFFF" />
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#29FFFFFF" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush"      Color="#EBFFFFFF" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8CFFFFFF" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="#52FFFFFF" />

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"      Color="#FFFF6E5C" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="#2EFF6E5C" />

    <!-- Graph -->
    <SolidColorBrush x:Key="EdgeBrush"       Color="#33FFFFFF" />
    <SolidColorBrush x:Key="EdgeActiveBrush" Color="#FFFF6E5C" />

    <!-- Accent gradient start/end for ExecuteButton -->
    <Color x:Key="AccentGradientStart">#FFFF6E5C</Color>
    <Color x:Key="AccentGradientEnd">#FFF24D80</Color>

</ResourceDictionary>
